# Secrets / credentials — never commit
.env
.env.*
*.pfx
*.pem
*.key

# Local / runtime-generated configs
configs/*.local.toml
configs/*.runtime_*.toml

# Runtime artifacts (SQLite stores, logs, caches, generated CSVs)
data/
log/
logs/
*.sqlite3
*.sqlite3-journal
*.sqlite3-wal
*.sqlite3-shm

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.tmp_pytest*/
.mypy_cache/
.ruff_cache/
*.egg-info/

# OS
.DS_Store
Thumbs.db
